# --- HTTP server ---
HTTP_PORT=8080
LOG_LEVEL=info

# --- OpenAI (required) ---
# Used for BOTH chat completion and embeddings via langchaingo.
OPENAI_API_KEY=sk-your-key-here
# Optional: override the API base URL (Azure OpenAI / proxy / OpenAI-compatible server).
# OPENAI_BASE_URL=

# --- Models ---
# Any OpenAI chat model works here: gpt-4o-mini, gpt-4o, gpt-4-turbo, gpt-3.5-turbo, ...
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
EMBEDDING_MODEL=text-embedding-3-small

# --- Retrieval-augmented generation tuning ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4
# Chunks embedded+stored per batch during async ingestion (affects polling granularity).
EMBED_BATCH_SIZE=64
